MEDIA_AGENT_MODE=live
MOCK_IMAGE_PROVIDER_ENABLED=false
ORCHESTRATION_MODE=runtime_first

DEFAULT_IMAGE_PROVIDER=openai_gpt_image
DEFAULT_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-2
# Default: openai_standard.  Use generation_only_square_b64 only for an
# explicitly certified gateway that accepts 1024x1024 text-to-image requests
# with response_format=b64_json and does not support image references. Use
# square_b64_reference_edit when that same restricted transport accepts
# reference/edit requests but not quality, output_format, or input_fidelity.
OPENAI_IMAGE_TRANSPORT_PROFILE=openai_standard
# Set only when a certified gateway needs a smaller transport prompt. The user
# request is retained; only repeated framework guidance may be compacted.
OPENAI_IMAGE_TRANSPORT_MAX_PROMPT_CHARS=0
OPENAI_IMAGE_LOCAL_MAX_REQUESTS_PER_MINUTE=12
OPENAI_IMAGE_LOCAL_MAX_OUTPUTS_PER_MINUTE=24
OPENAI_IMAGE_LOCAL_QUEUE_TIMEOUT_SECONDS=900
OPENAI_IMAGE_UPSTREAM_COOLDOWN_SECONDS=90
OPENAI_IMAGE_MAX_RETRY_AFTER_SECONDS=900
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_BASE_URL=

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-v4-pro-260425
BACKUP_LLM_PROVIDER=openai
BACKUP_LLM_MODEL=gpt-5.5
OPENAI_LLM_MODEL=gpt-5.5
KIMI_LLM_MODEL=kimi-for-coding
DEEPSEEK_LLM_MODEL=deepseek-v4-pro-260425
DEEPSEEK_LLM_BASE_URL=https://aiself.vip
LAB_LLM_PROVIDER=deepseek
LAB_LLM_MODEL=deepseek-v4-pro-260425
LAB_VISION_PROVIDER=doubao
LLM_PROMPT_PLANNING_ENABLED=true
IMAGE_WORK_INTENSITY=atelier

DEFAULT_VIDEO_PROVIDER=seedance

OPENAI_API_KEY=
OPENAI_BASE_URL=https://aiself.vip/v1
# Set true only when this OpenAI-compatible gateway owns upstream line
# failover, retry and backoff. V3 then keeps one request in flight per logical
# output and caps the entire client attempt at this budget.
OPENAI_IMAGE_GATEWAY_MANAGED_FAILOVER=false
OPENAI_IMAGE_GATEWAY_MANAGED_FAILOVER_TIMEOUT_SECONDS=240
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://aiself.vip
DEEPSEEK_LLM_API_KEY=
LAB_DOUBAO_VISION_API_KEY=
LAB_DOUBAO_VISION_BASE_URL=https://aiself.vip/v1
LAB_DOUBAO_VISION_MODEL=doubao-seed-2-0-lite-260428
GEMINI_IMAGE_API_KEY=
BYTEPLUS_API_KEY=

MEDIA_STORAGE_ROOT=.media_storage
