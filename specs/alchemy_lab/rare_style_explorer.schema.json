{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/alchemy-media-agent/specs/alchemy_lab/rare_style_explorer.schema.json",
  "title": "Alchemy Lab rare-style-explorer API contracts",
  "oneOf": [
    {
      "$ref": "#/$defs/styleListResponse"
    },
    {
      "$ref": "#/$defs/sessionResponse"
    },
    {
      "$ref": "#/$defs/moduleListResponse"
    }
  ],
  "$defs": {
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxSelectedStyles",
        "maxImagesPerStyle",
        "maxTotalImages",
        "maxConcurrentGenerations",
        "maxRetriesPerVariant",
        "maxGenerationIntervalSeconds",
        "defaultGenerationIntervalSeconds",
        "maxRateLimitBackoffSeconds",
        "styleLibrarySize"
      ],
      "properties": {
        "maxSelectedStyles": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "maxImagesPerStyle": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "maxTotalImages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "maxConcurrentGenerations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1
        },
        "maxRetriesPerVariant": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "maxGenerationIntervalSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60
        },
        "defaultGenerationIntervalSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "maxRateLimitBackoffSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "styleLibrarySize": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "moduleListResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modules"
      ],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "title",
              "description"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "styleListResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "styles",
        "limits",
        "families",
        "modes"
      ],
      "properties": {
        "styles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stylePreset"
          }
        },
        "limits": {
          "$ref": "#/$defs/limits"
        },
        "families": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labeledOption"
          }
        },
        "modes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labeledOption"
          }
        }
      }
    },
    "labeledOption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "sessionResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session",
        "board"
      ],
      "properties": {
        "session": {
          "$ref": "#/$defs/explorationSession"
        },
        "board": {
          "$ref": "#/$defs/comparisonBoard"
        },
        "async": {
          "type": "boolean"
        }
      }
    },
    "stylePreset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "display_name",
        "short_description",
        "family",
        "category",
        "tags",
        "mode_affinity",
        "prompt_directives",
        "negative_directives",
        "freshness",
        "is_beginner_default",
        "is_enabled"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{1,80}$"
        },
        "version": {
          "type": "string"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "short_description": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "enum": [
            "film",
            "fashion",
            "product",
            "photography",
            "illustration",
            "graphic",
            "craft",
            "digital",
            "space",
            "material"
          ]
        },
        "category": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mode_affinity": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "minimal",
              "product",
              "character",
              "poster",
              "scene",
              "material-series"
            ]
          }
        },
        "prompt_directives": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "negative_directives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "freshness": {
          "type": "string",
          "enum": [
            "normal",
            "high"
          ]
        },
        "is_beginner_default": {
          "type": "boolean"
        },
        "is_enabled": {
          "type": "boolean"
        }
      }
    },
    "explorationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idea"
      ],
      "properties": {
        "idea": {
          "type": "string",
          "minLength": 1
        },
        "selected_style_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 8
        },
        "mode": {
          "type": "string",
          "enum": [
            "minimal",
            "product",
            "character",
            "poster",
            "scene",
            "material-series"
          ]
        },
        "style_family": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "film",
            "fashion",
            "product",
            "photography",
            "illustration",
            "graphic",
            "craft",
            "digital",
            "space",
            "material",
            null
          ]
        },
        "freshness": {
          "type": "string",
          "enum": [
            "normal",
            "high"
          ]
        },
        "target_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "images_per_style": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "generation_interval_seconds": {
          "type": "number",
          "minimum": 0,
          "maximum": 60
        },
        "seed": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "style_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "avoid_generic": {
          "type": "boolean"
        },
        "aspect_ratio": {
          "type": [
            "string",
            "null"
          ]
        },
        "provider_preference": {
          "type": [
            "string",
            "null"
          ]
        },
        "quality_enhancement": {
          "type": "string",
          "enum": [
            "auto",
            "off",
            "balanced",
            "curated"
          ]
        },
        "reference_assets": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/referenceAssetInput"
          }
        },
        "reference_mode": {
          "type": "string",
          "enum": [
            "guided",
            "off"
          ]
        },
        "intent_director": {
          "type": "string",
          "enum": [
            "auto",
            "off"
          ]
        }
      }
    },
    "referenceAssetInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id"
      ],
      "properties": {
        "asset_id": {
          "type": "string"
        },
        "role": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "subject_reference",
            "product_reference",
            "logo_reference",
            "style_material_reference",
            "composition_reference",
            "negative_reference",
            null
          ]
        },
        "constraint_strength": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "required",
            "strong",
            "soft",
            null
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "explorationSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "feature",
        "status",
        "created_at",
        "updated_at",
        "request",
        "style_presets",
        "prompts",
        "variants",
        "favorites",
        "errors",
        "progress"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "feature": {
          "const": "rare-style-explorer"
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "completed",
            "partial_success",
            "failed",
            "cancelled"
          ]
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "request": {
          "$ref": "#/$defs/explorationRequest"
        },
        "style_presets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stylePreset"
          }
        },
        "prompts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/composedPrompt"
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/generationVariant"
          }
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/explorationError"
          }
        },
        "progress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "status": {
              "type": "string"
            },
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "completed": {
              "type": "integer",
              "minimum": 0
            },
            "failed": {
              "type": "integer",
              "minimum": 0
            },
            "pending": {
              "type": "integer",
              "minimum": 0
            },
            "percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "next_wait_seconds": {
              "type": "number",
              "minimum": 0
            },
            "message": {
              "type": "string"
            }
          }
        },
        "reference_plan": {
          "oneOf": [
            {
              "$ref": "#/$defs/referencePlan"
            },
            {
              "type": "null"
            }
          ]
        },
        "intent_plan": {
          "oneOf": [
            {
              "$ref": "#/$defs/intentPlan"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "composedPrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "session_id",
        "style_preset_id",
        "style_preset_version",
        "idea",
        "final_prompt",
        "prompt_metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "style_preset_id": {
          "type": "string"
        },
        "style_preset_version": {
          "type": "string"
        },
        "idea": {
          "type": "string"
        },
        "final_prompt": {
          "type": "string"
        },
        "prompt_metadata": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "quality_enhancement": {
              "$ref": "#/$defs/qualityEnhancementMetadata"
            },
            "intent_director": {
              "$ref": "#/$defs/publicIntentMetadata"
            },
            "reference_summary": {
              "type": [
                "string",
                "null"
              ]
            },
            "reference_asset_roles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/referenceRoleSummary"
              }
            },
            "reference_policy": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": true
                },
                {
                  "type": "null"
                }
              ]
            },
            "provider_input_plan": {
              "oneOf": [
                {
                  "$ref": "#/$defs/publicProviderInputPlan"
                },
                {
                  "type": "null"
                }
              ]
            },
            "reference_warnings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "referencePlan": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "asset_mode",
        "source",
        "summary",
        "public_summary",
        "assets",
        "warnings",
        "provider_input_plan"
      ],
      "properties": {
        "asset_mode": {
          "const": "lab_reference"
        },
        "source": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "public_summary": {
          "type": "string"
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provider_input_plan": {
          "$ref": "#/$defs/providerInputPlan"
        }
      }
    },
    "intentPlan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string"
        },
        "applied": {
          "type": "boolean"
        },
        "input_mode": {
          "type": "string"
        },
        "vision_source": {
          "type": "string"
        },
        "target_use": {
          "type": "string"
        },
        "confidence": {
          "type": "string"
        },
        "user_goal_summary": {
          "type": "string"
        },
        "reference_directives": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "style_routing": {
          "type": "object",
          "additionalProperties": true
        },
        "prompt_constraints": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "publicIntentMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "target_use",
        "confidence",
        "must_keep",
        "may_change",
        "avoid",
        "style_routing",
        "warnings"
      ],
      "properties": {
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "target_use": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "must_keep": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "may_change": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "style_routing": {
          "type": "object",
          "additionalProperties": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "referenceRoleSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "role_label",
        "constraint_strength"
      ],
      "properties": {
        "role": {
          "type": [
            "string",
            "null"
          ]
        },
        "role_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "constraint_strength": {
          "type": [
            "string",
            "null"
          ]
        },
        "director_directive": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "providerInputPlan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "operation": {
          "type": "string"
        },
        "requires_image_reference": {
          "type": "boolean"
        },
        "reference_image_count": {
          "type": "integer",
          "minimum": 0
        },
        "reference_asset_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsupported_provider_policy": {
          "type": "string"
        }
      }
    },
    "publicProviderInputPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "requires_image_reference",
        "reference_image_count",
        "roles",
        "unsupported_provider_policy"
      ],
      "properties": {
        "operation": {
          "type": [
            "string",
            "null"
          ]
        },
        "requires_image_reference": {
          "type": "boolean"
        },
        "reference_image_count": {
          "type": "integer",
          "minimum": 0
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsupported_provider_policy": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "qualityEnhancementMetadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "applied",
        "strategy",
        "text_hierarchy",
        "prompt_hygiene",
        "source"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "auto",
            "off",
            "balanced",
            "curated"
          ]
        },
        "applied": {
          "type": "boolean"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "off",
            "balanced",
            "curated"
          ]
        },
        "llm_provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "llm_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "llm_fallback_used": {
          "type": "boolean"
        },
        "text_hierarchy": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "applied",
            "has_text_intent",
            "text_roles"
          ],
          "properties": {
            "applied": {
              "type": "boolean"
            },
            "has_text_intent": {
              "type": "boolean"
            },
            "text_strategy_summary": {
              "type": "string"
            },
            "text_roles": {
              "type": "array",
              "maxItems": 6,
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "role_name",
                  "content",
                  "importance",
                  "rendering_policy",
                  "placement_intent"
                ],
                "properties": {
                  "role_name": {
                    "type": "string"
                  },
                  "content": {
                    "type": "string"
                  },
                  "importance": {
                    "type": "string",
                    "enum": [
                      "primary",
                      "secondary",
                      "tertiary",
                      "decorative"
                    ]
                  },
                  "rendering_policy": {
                    "type": "string",
                    "enum": [
                      "exact",
                      "semantic",
                      "decorative",
                      "avoid_rendering"
                    ]
                  },
                  "placement_intent": {
                    "type": "string"
                  }
                }
              }
            },
            "avoid_text": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "postprocess_recommendation": {
              "type": "string"
            }
          }
        },
        "art_direction_summary": {
          "type": "string"
        },
        "prompt_hygiene": {
          "type": "object",
          "additionalProperties": true
        },
        "source": {
          "type": "string"
        },
        "error": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      }
    },
    "qualityEnhancementSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quality_enhancement_mode",
        "quality_enhancement_strategy",
        "quality_enhancement_applied",
        "text_hierarchy_applied",
        "text_hierarchy_summary",
        "art_direction_summary"
      ],
      "properties": {
        "quality_enhancement_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "auto",
            "off",
            "balanced",
            "curated",
            null
          ]
        },
        "quality_enhancement_strategy": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "off",
            "balanced",
            "curated",
            null
          ]
        },
        "quality_enhancement_applied": {
          "type": "boolean"
        },
        "text_hierarchy_applied": {
          "type": "boolean"
        },
        "text_hierarchy_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "art_direction_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "generationVariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "session_id",
        "prompt_id",
        "style_preset_id",
        "index_within_style",
        "status",
        "created_at",
        "provider_metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "prompt_id": {
          "type": "string"
        },
        "style_preset_id": {
          "type": "string"
        },
        "index_within_style": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "running",
            "succeeded",
            "failed",
            "cancelled"
          ]
        },
        "created_at": {
          "type": "string"
        },
        "completed_at": {
