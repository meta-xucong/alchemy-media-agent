IDENTITY_SIDECAR_BACKEND=comfyui
IDENTITY_SIDECAR_API_KEY=replace-with-a-long-random-secret
IDENTITY_PROVIDER_FAMILY=photomaker
IDENTITY_MODEL_NAME=photomaker-v2

# These gates must stay false until an operator verifies the exact workflow,
# model weights, face encoder, base model, and dependency licenses.
IDENTITY_MODEL_LICENSE_CONFIRMED=false
IDENTITY_CONDITIONING_CONFIRMED=false
IDENTITY_LOCAL_REPAIR_CONFIRMED=false

IDENTITY_WORKFLOW_PATH=/workflows/identity.json
IDENTITY_REPAIR_WORKFLOW_PATH=
COMFYUI_BASE_URL=http://host.docker.internal:8188
COMFYUI_API_KEY=
COMFYUI_OUTPUT_NODE_IDS=

IDENTITY_REQUEST_TIMEOUT_SECONDS=420
IDENTITY_HEALTH_TIMEOUT_SECONDS=10
IDENTITY_CAPABILITY_TTL_SECONDS=15
IDENTITY_POLL_INTERVAL_SECONDS=1
IDENTITY_MAX_CONCURRENCY=1
IDENTITY_MAX_REFERENCES=3
IDENTITY_MAX_FILE_BYTES=2000000
IDENTITY_MAX_TOTAL_UPLOAD_BYTES=8000000
IDENTITY_MAX_PROMPT_CHARS=18000
IDENTITY_MAX_OUTPUT_BYTES=32000000
IDENTITY_IDEMPOTENCY_TTL_SECONDS=180
IDENTITY_IDEMPOTENCY_MAX_ENTRIES=4
