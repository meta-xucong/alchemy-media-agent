{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "V3 production text-pixel font manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "fonts"],
  "properties": {
    "manifest_version": {"type": "string", "minLength": 1},
    "fonts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "font_id",
          "version",
          "file_path",
          "license_id",
          "license_evidence_reference",
          "expected_sha256",
          "supported_locales",
          "production_approved"
        ],
        "properties": {
          "font_id": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "file_path": {"type": "string", "minLength": 1},
          "license_id": {"type": "string", "minLength": 1},
          "license_evidence_reference": {"type": "string", "minLength": 1},
          "expected_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
          "supported_locales": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": ["en-US", "zh-CN", "ru-RU"]}
          },
          "production_approved": {"const": true}
        }
      }
    }
  }
}
